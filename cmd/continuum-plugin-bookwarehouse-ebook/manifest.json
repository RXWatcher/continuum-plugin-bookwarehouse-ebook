{
  "plugin_id": "continuum.bookwarehouse-ebook",
  "version": "0.1.0",
  "checksum": "__CHECKSUM__",
  "continuum_api_version": "v1",
  "capabilities": [
    {"type": "http_routes.v1", "id": "backend",
     "display_name": "BookWarehouse ebook backend",
     "description": "Calibre-backed ebook source: catalog, file streaming, request forwarding."},
    {"type": "event_consumer.v1", "id": "request_handler",
     "display_name": "Request handler",
     "description": "Forwards ebook request_submitted events to BookWarehouse monitoring.",
     "subscriptions": ["plugin.continuum.ebooks.request_submitted"]},
    {"type": "ebook_backend.v1", "id": "default",
     "display_name": "BookWarehouse (Calibre)",
     "description": "Owned-library ebook source backed by an external BookWarehouse instance."},
    {"type": "scheduled_task.v1", "id": "reconciler",
     "display_name": "Reconcile BookWarehouse request status",
     "description": "Polls upstream BookWarehouse for status changes on non-terminal requests.",
     "cron": "*/1 * * * *"}
  ],
  "http_routes": [
    {"id": "api", "method": "*", "path": "/api/v1/*", "access": "authenticated"}
  ],
  "global_config_schema": [
    {"key": "database_url", "title": "Postgres connection string",
     "description": "DSN for the dedicated bookwarehouse_ebook schema (e.g. postgres://plugin_bookwarehouse_ebook:...@host:5432/continuum?search_path=bookwarehouse_ebook&sslmode=disable).",
     "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
     "required": true,
     "admin_form": {"fields": [{"key": "value", "label": "Connection URL", "control": "ADMIN_FORM_CONTROL_PASSWORD", "required": true, "secret": true}]}},
    {"key": "base_url", "title": "BookWarehouse base URL",
     "description": "e.g. https://bookwarehouse.example.com (no trailing slash).",
     "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
     "required": true,
     "admin_form": {"fields": [{"key": "value", "label": "URL", "control": "ADMIN_FORM_CONTROL_TEXT", "required": true}]}},
    {"key": "api_key", "title": "BookWarehouse API key",
     "description": "X-API-Key header for upstream calls.",
     "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
     "required": true,
     "admin_form": {"fields": [{"key": "value", "label": "API key", "control": "ADMIN_FORM_CONTROL_PASSWORD", "required": true, "secret": true}]}},
    {"key": "default_cover_size", "title": "Default cover size",
     "description": "One of small|medium|large|original. Defaults to large.",
     "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
     "admin_form": {"fields": [{"key": "value", "label": "Cover size", "control": "ADMIN_FORM_CONTROL_TEXT"}]}},
    {"key": "request_quality_profile", "title": "Request quality profile",
     "description": "BookWarehouse-side quality tier for new requests.",
     "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
     "admin_form": {"fields": [{"key": "value", "label": "Profile", "control": "ADMIN_FORM_CONTROL_TEXT"}]}},
    {"key": "enable_auto_monitoring", "title": "Enable auto-monitoring",
     "description": "Allow Sonarr-style auto-monitoring for new requests (book is searched until found).",
     "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"boolean\"}}}",
     "admin_form": {"fields": [{"key": "value", "label": "Auto-monitor new requests", "control": "ADMIN_FORM_CONTROL_CHECKBOX"}]}}
  ]
}
